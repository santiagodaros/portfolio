---

<section id="experience" class="border-b border-border">
  <div class="max-w-[1200px] mx-auto px-5 sm:px-10 py-16">
    <p class="section-label animate-on-scroll" data-es="02 // experiencia.log" data-en="02 // experience.log">02 // experiencia.log</p>
    <h2 class="section-heading mb-8 animate-on-scroll">
      <span data-es="Trayectoria " data-en="Professional ">Trayectoria </span><span class="accent-serif" data-es="profesional" data-en="journey">profesional</span>
    </h2>

    <div class="flex flex-col gap-3.5">
      {experiences.map((exp, i) => (
        <div class="box-alt p-6 animate-on-scroll" style={`transition-delay: ${i * 0.08}s`}>
          <div class="flex justify-between items-baseline flex-wrap gap-2.5">
            <h3 class="font-mono font-bold text-[17px] text-text-primary">
              {exp.role} <span class="font-normal text-text-secondary">@ {exp.company}</span>
            </h3>
            {exp.current && (
              <div class="font-mono font-semibold text-[11px] text-tgreen border px-2 py-[3px]" style="border-color: var(--color-green)" data-es="actual" data-en="current">
                actual
              </div>
            )}
          </div>
          <div class="mt-1.5 font-mono text-xs text-text-muted">
            <span data-es={exp.periodEs} data-en={exp.periodEn}>{exp.periodEs}</span> — <span data-es={exp.metaEs} data-en={exp.metaEn}>{exp.metaEs}</span>
          </div>

          <p class="mt-3.5 font-mono text-[13.5px] leading-relaxed text-text-secondary max-w-[700px]" data-es={exp.descriptionEs} data-en={exp.descriptionEn}>{exp.descriptionEs}</p>

          <div class="mt-3 flex flex-col gap-1.5">
            {exp.achievementsEs.map((a, j) => (
              <div class="flex gap-2 font-mono text-[13px] leading-normal text-text-secondary max-w-[720px]">
                <span class="text-accent shrink-0">▸</span>
                <span data-i18n="es" set:html={hl(a)} />
                <span data-i18n="en" set:html={hl(exp.achievementsEn[j])} />
              </div>
            ))}
          </div>

          <div class="mt-3.5 flex flex-wrap gap-2">
            {exp.tags.map((tag) => (
              <span class="chip">#{tag}</span>
            ))}
          </div>
        </div>
      ))}

      <!-- Education -->
      <div class="box p-6 animate-on-scroll">
        <div class="flex justify-between items-baseline flex-wrap gap-2.5">
          <h3 class="font-mono font-bold text-[17px] text-text-primary">🎓 <span data-es={education.titleEs} data-en={education.titleEn}>{education.titleEs}</span></h3>
          <div class="font-mono font-semibold text-[11px] text-accent border border-accent/40 px-2 py-[3px]" data-es="cursando" data-en="in progress">cursando</div>
        </div>
        <div class="mt-1.5 font-mono text-xs text-text-muted">{education.place} — {education.period}</div>
        <p class="mt-3 font-mono text-[13.5px] leading-relaxed text-text-secondary max-w-[720px]" data-es={education.descEs} data-en={education.descEn}>{education.descEs}</p>
      </div>
    </div>
  </div>
</section>
