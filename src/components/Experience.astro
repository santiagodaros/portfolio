---
const experiences = [
  {
    role: 'Cloud Demand Hub Trainee',
    company: 'readymind',
    period: 'Oct 2025 — Presente',
    periodEn: 'Oct 2025 — Present',
    duration: '7 meses',
    durationEn: '7 months',
    location: 'Buenos Aires, Argentina',
    current: true,
    descriptionEs:
      'Soporte en operaciones Cloud dentro del equipo de readymind, con foco en entornos Microsoft Azure híbridos.',
    descriptionEn:
      'Cloud operations support within the readymind team, focused on hybrid Microsoft Azure environments.',
    achievementsEs: [
      'Gestión de incidentes y operaciones en entornos Azure híbridos, atendiendo tickets y manteniendo los SLAs del equipo',
      'Implementación y evaluación de Azure Arc sobre servidores, integrando infraestructura on-premises con la nube',
      'Administración de dispositivos con Microsoft Intune, incluyendo despliegue de políticas y configuraciones',
      'Participación en iniciativas de optimización de costos en suscripciones Azure, contribuyendo a la optimización mediante relevamiento de FinOps',
      'Certificaciones obtenidas durante el rol: AZ-104 (Azure Administrator) y AZ-800/801 (Windows Server Hybrid Admin)',
    ],
    achievementsEn: [
      'Incident and operations management in hybrid Azure environments, handling tickets and maintaining team SLAs',
      'Implementation and evaluation of Azure Arc on servers, integrating on-premises infrastructure with the cloud',
      'Device management with Microsoft Intune, including policy and configuration deployment',
      'Participation in cost optimization initiatives in Azure subscriptions, contributing through FinOps assessment',
      'Certifications obtained during the role: AZ-104 (Azure Administrator) and AZ-800/801 (Windows Server Hybrid Admin)',
    ],
    tags: ['Azure', 'Azure Arc', 'Intune', 'AZ-104', 'AZ-800/801', 'Windows Server'],
  },
  {
    role: 'Cloud Engineer',
    company: 'readymind',
    period: 'May 2025 — Oct 2025',
    periodEn: 'May 2025 — Oct 2025',
    duration: '6 meses',
    durationEn: '6 months',
    location: 'Buenos Aires, Argentina',
    current: false,
    descriptionEs:
      'Programa intensivo de 6 meses en Cloud, Data y Low-Code dentro de readymind.',
    descriptionEn:
      'Intensive 6-month program in Cloud, Data, and Low-Code within readymind.',
    achievementsEs: [
      'Completé un programa intensivo de 6 meses en Cloud, Data y Low-Code, obteniendo excelentes resultados en certificaciones y practicando con casos de estudio',
      'Adquirí competencias prácticas en Microsoft Azure a través de laboratorios, proyectos y evaluaciones técnicas',
      'Obtuve 3 certificaciones Microsoft (AZ-900, DP-900, PL-900) durante el programa, demostrando dominio acelerado del ecosistema Azure',
    ],
    achievementsEn: [
      'Completed an intensive 6-month program in Cloud, Data, and Low-Code, achieving excellent results in certifications and practicing with case studies',
      'Acquired practical skills in Microsoft Azure through labs, projects, and technical assessments',
      'Obtained 3 Microsoft certifications (AZ-900, DP-900, PL-900) during the program, demonstrating accelerated mastery of the Azure ecosystem',
    ],
    tags: ['Azure', 'Azure Data Factory', 'Azure Cosmos DB', 'Power Platform', 'AZ-900', 'DP-900', 'PL-900'],
  },
];
---

<section id="experience" class="pt-24 sm:pt-32 pb-12 bg-surface-1">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-16">
      <p class="section-title animate-on-scroll"
         data-es="Experiencia"
         data-en="Experience">Experiencia</p>
      <h2 class="section-heading animate-on-scroll"
          data-es="Trayectoria profesional"
          data-en="Professional Journey">Trayectoria profesional</h2>
    </div>

    <div class="relative">
      <!-- Timeline line -->
      <div class="absolute left-0 top-0 w-px bg-border hidden md:block ml-6" style="height: calc(100% - 3rem)"></div>

      <div class="space-y-12">
        {experiences.map((exp, i) => (
          <div class="relative md:pl-20 animate-on-scroll" style={`animation-delay: ${i * 0.15}s`}>
            <!-- Timeline dot -->
            <div class="absolute left-0 top-6 hidden md:flex items-center justify-center w-12 h-12 rounded-full bg-surface-3 border border-border z-10">
              {exp.current ? (
                <span class="glow-dot"></span>
              ) : (
                <div class="w-2 h-2 rounded-full bg-accent/50" style="animation: timeline-dot-pulse 2.5s ease-in-out infinite;"></div>
              )}
            </div>

            <div class="card group">
              <div class="flex flex-col sm:flex-row sm:items-start justify-between gap-4 mb-4">
                <div>
                  <div class="flex items-center gap-2 mb-1">
                    <h3 class="font-semibold text-text-primary text-lg">{exp.role}</h3>
                    {exp.current && (
                      <span class="text-xs px-2 py-0.5 rounded-full bg-accent/10 text-accent border border-accent/20 font-mono"
                            data-es="actual"
                            data-en="current">
                        actual
                      </span>
                    )}
                  </div>
                  <p class="text-text-secondary font-medium">{exp.company}</p>
                </div>
                <div class="text-right shrink-0">
                  <p class="text-xs font-mono text-text-muted"
                     data-es={exp.period}
                     data-en={exp.periodEn}>{exp.period}</p>
                  <p class="text-xs text-text-muted mt-0.5">
                    <span data-es={exp.duration} data-en={exp.durationEn}>{exp.duration}</span>
                    {' · '}{exp.location}
                  </p>
                </div>
              </div>

              <p class="text-text-secondary text-sm leading-relaxed mb-4"
                 data-es={exp.descriptionEs}
                 data-en={exp.descriptionEn}>{exp.descriptionEs}</p>

              <ul class="space-y-2 mb-5">
                {exp.achievementsEs.map((a, j) => (
                  <li class="flex items-start gap-2 text-sm text-text-secondary">
                    <span class="text-accent mt-0.5 shrink-0">▸</span>
                    <span data-es={a} data-en={exp.achievementsEn[j]}>{a}</span>
                  </li>
                ))}
              </ul>

              <div class="flex flex-wrap gap-2">
                {exp.tags.map((tag) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Education -->
    <div class="mt-16 animate-on-scroll">
      <h3 class="text-sm font-mono text-text-muted uppercase tracking-widest mb-6"
          data-es="Educacion"
          data-en="Education">Educacion</h3>
      <div class="card flex flex-col sm:flex-row sm:items-center justify-between gap-4">
        <div class="flex items-center gap-4">
          <div class="w-10 h-10 rounded-lg bg-surface-4 border border-border flex items-center justify-center text-lg shrink-0">
            🎓
          </div>
          <div>
            <p class="font-semibold text-text-primary"
               data-es="Licenciatura en Ciencias de la Computacion"
               data-en="Bachelor's in Computer Science">Licenciatura en Ciencias de la Computacion</p>
            <p class="text-text-secondary text-sm">Universidad de Buenos Aires (UBA) — FCEN</p>
          </div>
        </div>
        <span class="text-xs font-mono text-text-muted shrink-0">2023 — 2029</span>
      </div>
    </div>
  </div>
</section>
