---
// Highlights standalone metrics (20, ~2 hs, 45 min, ~60%) in accent.
// Lookbehind skips cert codes like AZ-104 / AZ-800/801.
function hl(text: string): string {
  return text.replace(
    /(?<!AZ-|DP-|PL-|-)(~?\d[\d.,/]*\s?(?:%|hs|hrs|min)?)/g,
    '<strong class="text-accent font-semibold">$1</strong>'
  );
}

