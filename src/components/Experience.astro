---
const experiences = [
  {
    role: 'Cloud Demand Hub Trainee',
    company: 'readymind',
    period: 'Oct 2025 — Presente',
    meta: 'Buenos Aires, Argentina · Híbrido · ~7 meses · Full-time',
    current: true,
    description:
      'Soporte en operaciones Cloud dentro del equipo de readymind, con foco en entornos Microsoft Azure híbridos.',
    achievements: [
      'Gestión de incidentes y operaciones en entornos Azure híbridos, atendiendo tickets y manteniendo los SLAs del equipo',
      'Implementación y evaluación de Azure Arc sobre servidores, integrando infraestructura on-premises con la nube',
      'Administración de dispositivos con Microsoft Intune, incluyendo despliegue de políticas y configuraciones',
      'Participación en iniciativas de optimización de costos en suscripciones Azure, contribuyendo a la optimización mediante relevamiento de FinOps',
      'Certificaciones obtenidas durante el rol: AZ-104 (Azure Administrator) y AZ-800/801 (Windows Server Hybrid Admin)',
    ],
    tags: ['Azure', 'Azure Arc', 'Intune', 'AZ-104', 'AZ-800/801', 'Windows Server'],
  },
  {
    role: 'Cloud Engineer',
    company: 'readymind',
    period: 'May 2025 — Oct 2025',
    meta: 'Buenos Aires, Argentina · Híbrido · ~6 meses · Part-time',
    current: false,
    description:
      'Programa intensivo de 6 meses en Cloud, Data y Low-Code dentro de readymind.',
    achievements: [
      'Completé un programa intensivo de 6 meses en Cloud, Data y Low-Code, obteniendo excelentes resultados en certificaciones y practicando con casos de estudio',
      'Adquirí competencias prácticas en Microsoft Azure a través de laboratorios, proyectos y evaluaciones técnicas',
      'Obtuve 3 certificaciones Microsoft (AZ-900, DP-900, PL-900) durante el programa, demostrando dominio acelerado del ecosistema Azure',
    ],
    tags: ['Azure', 'Azure Data Factory', 'Azure Cosmos DB', 'Power Platform', 'AZ-900', 'DP-900', 'PL-900'],
  },
];

const education = {
  title: 'Licenciatura en Ciencias de la Computación',
  place: 'Universidad de Buenos Aires (UBA) — FCEN',
  period: '2023 — 2029',
  desc: 'Formación en algoritmos, sistemas y teoría de la computación.',
};
---

<section id="experience" class="border-b border-border">
  <div class="max-w-[1200px] mx-auto px-5 sm:px-10 py-16">
    <p class="section-label animate-on-scroll">02 // experiencia.log</p>
    <h2 class="section-heading mb-8 animate-on-scroll">
      Trayectoria <span class="accent-serif">profesional</span>
    </h2>

    <div class="flex flex-col gap-3.5">
      {experiences.map((exp, i) => (
        <div class="box-alt p-6 animate-on-scroll" style={`transition-delay: ${i * 0.08}s`}>
          <div class="flex justify-between items-baseline flex-wrap gap-2.5">
            <div class="font-mono font-bold text-[17px] text-text-primary">
              {exp.role} <span class="font-normal text-text-secondary">@ {exp.company}</span>
            </div>
            {exp.current && (
              <div class="font-mono font-semibold text-[11px] text-tgreen border px-2 py-[3px]" style="border-color: var(--color-green)">
                actual
              </div>
            )}
          </div>
          <div class="mt-1.5 font-mono text-xs text-text-muted">{exp.period} — {exp.meta}</div>

          <p class="mt-3.5 font-mono text-[13.5px] leading-relaxed text-text-secondary max-w-[700px]">{exp.description}</p>

          <div class="mt-3 flex flex-col gap-1.5">
            {exp.achievements.map((a) => (
              <div class="flex gap-2 font-mono text-[13px] leading-normal text-text-secondary max-w-[720px]">
                <span class="text-accent shrink-0">▸</span>
                <span>{a}</span>
              </div>
            ))}
          </div>

          <div class="mt-3.5 flex flex-wrap gap-2">
            {exp.tags.map((tag) => (
              <span class="chip">#{tag}</span>
            ))}
          </div>
        </div>
      ))}

      <!-- Education -->
      <div class="box p-6 animate-on-scroll">
        <div class="font-mono font-bold text-[17px] text-text-primary">🎓 {education.title}</div>
        <div class="mt-1.5 font-mono text-xs text-text-muted">{education.place} — {education.period}</div>
        <p class="mt-3 font-mono text-[13.5px] text-text-secondary">{education.desc}</p>
      </div>
    </div>
  </div>
</section>
