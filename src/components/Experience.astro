---
const experiences = [
  {
    role: 'Cloud Demand Hub Trainee',
    company: 'readymind',
    period: 'Oct 2025 — Presente',
    duration: '6 meses',
    location: 'Buenos Aires, Argentina',
    current: true,
    description:
      'Soporte en operaciones Cloud dentro del equipo de readymind, con foco en entornos Microsoft Azure. Colaboro en la gestión de incidentes, documentación técnica y proyectos de modernización de infraestructura.',
    achievements: [
      'Soporte en la gestión de incidentes y operaciones en entornos de nube',
      'Creación y documentación de procedimientos técnicos y operativos',
      'Colaboración en implementaciones de Azure Arc y gestión de dispositivos con Intune',
      'Participación en procesos de estandarización, control de costos y optimización de recursos en Azure',
      'Obtención de la certificación AZ-104 (Azure Administrator Associate)',
      'Aprobación del examen AZ-800 (Windows Server Hybrid Administrator Associate - Parte 1)',
    ],
    tags: ['Azure', 'Azure Arc', 'Intune', 'AZ-104', 'AZ-800', 'Windows Server'],
  },
  {
    role: 'Cloud Engineer',
    company: 'readymind',
    period: 'May 2025 — Oct 2025',
    duration: '6 meses',
    location: 'Buenos Aires, Argentina',
    current: false,
    description:
      'Programa intensivo de capacitación en tecnologías Cloud, Low-Code y Data dentro de readymind. Adquisición de competencias prácticas sobre Microsoft Azure y sus principales servicios.',
    achievements: [
      'Finalización de un programa intensivo de capacitación en Cloud, Low-Code y Data',
      'Enfoque en la adquisición de competencias sobre Microsoft Azure y sus principales servicios',
      'Obtención de la certificación AZ-900 (Azure Fundamentals)',
      'Obtención de la certificación DP-900 (Azure Data Fundamentals)',
      'Obtención de la certificación PL-900 (Power Platform Fundamentals)',
    ],
    tags: ['Azure', 'Azure Data Factory', 'Azure Cosmos DB', 'Power Platform', 'AZ-900', 'DP-900', 'PL-900'],
  },
];
---

<section id="experience" class="pt-24 sm:pt-32 pb-12 bg-surface-1">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-16">
      <p class="section-title animate-on-scroll">Experiencia</p>
      <h2 class="section-heading animate-on-scroll">Trayectoria profesional</h2>
    </div>

    <div class="relative">
      <!-- Timeline line -->
      <div class="absolute left-0 top-0 w-px bg-border hidden md:block ml-6" style="height: calc(100% - 3rem)"></div>

      <div class="space-y-12">
        {experiences.map((exp, i) => (
          <div class="relative md:pl-20 animate-on-scroll" style={`animation-delay: ${i * 0.15}s`}>
            <!-- Timeline dot -->
            <div class="absolute left-0 top-6 hidden md:flex items-center justify-center w-12 h-12 rounded-full bg-surface-3 border border-border z-10">
              {exp.current ? (
                <span class="glow-dot"></span>
              ) : (
                <div class="w-2 h-2 rounded-full bg-accent/50" style="animation: timeline-dot-pulse 2.5s ease-in-out infinite;"></div>
              )}
            </div>

            <div class="card group">
              <div class="flex flex-col sm:flex-row sm:items-start justify-between gap-4 mb-4">
                <div>
                  <div class="flex items-center gap-2 mb-1">
                    <h3 class="font-semibold text-text-primary text-lg">{exp.role}</h3>
                    {exp.current && (
                      <span class="text-xs px-2 py-0.5 rounded-full bg-accent/10 text-accent border border-accent/20 font-mono">
                        actual
                      </span>
                    )}
                  </div>
                  <p class="text-text-secondary font-medium">{exp.company}</p>
                </div>
                <div class="text-right shrink-0">
                  <p class="text-xs font-mono text-text-muted">{exp.period}</p>
                  <p class="text-xs text-text-muted mt-0.5">{exp.duration} · {exp.location}</p>
                </div>
              </div>

              <p class="text-text-secondary text-sm leading-relaxed mb-4">{exp.description}</p>

              <ul class="space-y-2 mb-5">
                {exp.achievements.map((a) => (
                  <li class="flex items-start gap-2 text-sm text-text-secondary">
                    <span class="text-accent mt-0.5 shrink-0">▸</span>
                    {a}
                  </li>
                ))}
              </ul>

              <div class="flex flex-wrap gap-2">
                {exp.tags.map((tag) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Education -->
    <div class="mt-16 animate-on-scroll">
      <h3 class="text-sm font-mono text-text-muted uppercase tracking-widest mb-6">Educacion</h3>
      <div class="card flex flex-col sm:flex-row sm:items-center justify-between gap-4">
        <div class="flex items-center gap-4">
          <div class="w-10 h-10 rounded-lg bg-surface-4 border border-border flex items-center justify-center text-lg shrink-0">
            🎓
          </div>
          <div>
            <p class="font-semibold text-text-primary">Licenciatura en Ciencias de la Computacion</p>
            <p class="text-text-secondary text-sm">Universidad de Buenos Aires (UBA) — FCEN</p>
          </div>
        </div>
        <span class="text-xs font-mono text-text-muted shrink-0">2023 — 2029</span>
      </div>
    </div>
  </div>
</section>
