  { name: 'Active Directory',   color: '#0078D4', svg: '<path stroke-linecap="round" stroke-linejoin="round" d="M17 20v-2a4 4 0 0 0-4-4H7a4 4 0 0 0-4 4v2m7-10a4 4 0 1 0 0-8 4 4 0 0 0 0 8zm6 2a3 3 0 1 0 0-6 3 3 0 0 0 0 6m2 7v-1a3 3 0 0 0-2.5-2.96"/>' },
