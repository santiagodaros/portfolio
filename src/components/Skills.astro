---

<section id="skills" class="py-24 sm:py-32">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 relative overflow-hidden">
    <span class="section-deco-number">03</span>
    <div class="mb-12">
      <p class="section-title animate-from-left"
         data-es="Stack & Habilidades"
         data-en="Stack & Skills">Stack & Habilidades</p>
      <h2 class="section-heading animate-from-left" style="transition-delay:80ms"
          data-es="Tecnologias e idiomas"
          data-en="Technologies & Languages">Tecnologias e idiomas</h2>
    </div>

    <div class="grid lg:grid-cols-3 gap-8">
      <!-- Skills tags -->
      <div class="animate-from-left" style="transition-delay:80ms">
        <h3 class="text-xs font-mono text-text-muted uppercase tracking-widest mb-4"
            data-es="Tecnologias"
            data-en="Technologies">Tecnologias</h3>
        <div class="flex flex-wrap gap-2">
          {skills.map((skill) => (
            <span class="tag hover:border-accent/40 hover:text-text-primary hover:bg-surface-3 transition-all duration-200 cursor-default flex items-center gap-1.5">
              {skill.devicon ? (
                <i class={`${skill.devicon} text-base leading-none`}></i>
              ) : (
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none"
                     stroke={skill.color} stroke-width="2" class="shrink-0"
                     set:html={skill.svg} />
              )}
              {skill.name}
            </span>
          ))}
        </div>
      </div>

      <!-- Certifications -->
      <div class="animate-on-scroll" style="transition-delay: 160ms">
        <h3 class="text-xs font-mono text-text-muted uppercase tracking-widest mb-4"
            data-es="Certificaciones Microsoft"
            data-en="Microsoft Certifications">Certificaciones Microsoft</h3>
        <div class="space-y-2">
          {certifications.map((cert) => (
            <details class="cert-card group rounded-lg bg-surface-2 border border-border hover:border-accent/40 transition-colors duration-200">
              <summary class="flex items-center gap-3 p-3 cursor-pointer list-none select-none">
                <!-- Code pill -->
                <span class={`font-mono font-bold text-xs shrink-0 px-2 py-1 rounded-md border text-center leading-tight w-[4.5rem] transition-colors ${
                  cert.levelEs === 'Associate'
                    ? 'bg-violet-500/15 text-violet-300 border-violet-500/25 group-open:bg-violet-500/25'
                    : 'bg-sky-500/15 text-sky-300 border-sky-500/25 group-open:bg-sky-500/25'
                }`}>
                  {cert.name}
                </span>

                <!-- Name + date -->
                <div class="flex-1 min-w-0">
                  <p class="text-text-primary text-xs font-medium leading-snug">{cert.full}</p>
                  <p class="text-text-muted text-[10px] font-mono mt-0.5"
                     data-es={cert.date}
                     data-en={cert.dateEn}>{cert.date}</p>
                </div>

                <!-- Level tag -->
                <span class={`text-[10px] font-mono px-1.5 py-0.5 rounded shrink-0 hidden sm:inline ${
                  cert.levelEs === 'Associate'
                    ? 'bg-violet-500/15 text-violet-300 border border-violet-500/25'
                    : 'bg-sky-500/15 text-sky-300 border border-sky-500/25'
                }`}
                  data-es={cert.levelEs}
                  data-en={cert.levelEn}
                >{cert.levelEs}</span>

                <!-- Chevron -->
                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-text-muted shrink-0 transition-transform duration-200 group-open:rotate-180">
                  <path d="m6 9 6 6 6-6"/>
                </svg>
              </summary>

              <!-- Expanded content -->
              <div class="px-3 pb-3">
                <div class="pt-2.5 border-t border-border/60">
                  <p class="text-text-secondary text-xs leading-relaxed mb-3"
                     data-es={cert.descEs}
                     data-en={cert.descEn}>{cert.descEs}</p>
                  <a
                    href={cert.link}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-1.5 text-accent text-xs font-semibold hover:text-accent-dim transition-colors"
                    onclick="event.stopPropagation()"
                  >
                    <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></svg>
                    <span data-es="Verificar credencial" data-en="Verify credential">Verificar credencial</span>
                  </a>
                </div>
              </div>
            </details>
          ))}
        </div>
      </div>

      <!-- Languages -->
      <div class="animate-from-right" style="transition-delay: 240ms">
        <h3 class="text-xs font-mono text-text-muted uppercase tracking-widest mb-4"
            data-es="Idiomas"
            data-en="Languages">Idiomas</h3>
        <div class="space-y-2.5">
          {languages.map((lang) => (
            <div class="flex items-center gap-3 p-3 rounded-lg bg-surface-2 border border-border hover:border-border-hover transition-colors">
              <span class="text-xl shrink-0">{lang.flag}</span>
              <div>
                <p class="text-text-primary text-sm font-medium"
                   data-es={lang.nameEs}
                   data-en={lang.nameEn}>{lang.nameEs}</p>
                <p class="text-text-muted text-xs"
                   data-es={lang.levelEs}
                   data-en={lang.levelEn}>{lang.levelEs}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
