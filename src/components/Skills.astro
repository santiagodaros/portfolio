const languages = [
  { nameEs: 'Español', nameEn: 'Spanish', levelEs: 'Nativo', levelEn: 'Native', flag: '🇦🇷' },
  { nameEs: 'Inglés', nameEn: 'English', levelEs: 'Professional Working', levelEn: 'Professional Working', flag: '🇺🇸' },
  { nameEs: 'Alemán', nameEn: 'German', levelEs: 'Professional Working', levelEn: 'Professional Working', flag: '🇩🇪' },
