---
const navLinks = [
  { href: '#about', labelEs: 'Sobre mi', labelEn: 'About' },
  { href: '#experience', labelEs: 'Experiencia', labelEn: 'Experience' },
  { href: '#skills', labelEs: 'Stack', labelEn: 'Stack' },
  { href: '#articles', labelEs: 'Articulos', labelEn: 'Articles' },
  { href: '#contact', labelEs: 'Contacto', labelEn: 'Contact' },
];
---

<header
  id="nav"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
>
  <nav class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/" class="flex items-center">
        <img src="/favicon.svg" alt="Logo" class="h-9 w-9" />
      </a>

      <!-- Desktop nav -->
      <ul class="hidden md:flex items-center gap-1">
        {navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class="px-3 py-2 text-sm text-text-secondary hover:text-text-primary rounded-lg transition-colors hover:bg-surface-3"
              data-es={link.labelEs}
              data-en={link.labelEn}
            >
              {link.labelEs}
            </a>
          </li>
        ))}
      </ul>

      <!-- Right side controls -->
      <div class="hidden md:flex items-center gap-2">
        <!-- CTA -->
        <a
          href="mailto:santidros@example.com"
          class="inline-flex btn-outline text-xs py-2 px-4"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
          </svg>
          <span data-es="Hablemos" data-en="Let's talk">Hablemos</span>
        </a>

        <!-- Language toggle -->
        <button
          id="lang-toggle"
          class="flex items-center gap-1.5 text-sm font-medium text-gray-600 dark:text-gray-300 hover:text-violet-600 dark:hover:text-violet-400 transition-colors p-2 rounded-lg hover:bg-surface-3"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
          </svg>
          <span id="lang-label">English</span>
        </button>
      </div>

      <!-- Theme toggle -->
      <button
        id="theme-toggle"
        class="p-2 rounded-lg text-text-secondary hover:text-text-primary hover:bg-surface-3 transition-colors"
        aria-label="Cambiar tema"
      >
        <!-- Moon (dark mode) -->
        <svg id="icon-moon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/>
        </svg>
        <!-- Sun (light mode) -->
        <svg id="icon-sun" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden">
          <circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/>
        </svg>
      </button>

      <!-- Mobile menu button -->
      <button
        id="menu-btn"
        class="md:hidden p-2 rounded-lg text-text-secondary hover:text-text-primary hover:bg-surface-3 transition-colors"
        aria-label="Menu"
      >
        <svg id="icon-open" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/>
        </svg>
        <svg id="icon-close" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden">
          <path d="M18 6 6 18"/><path d="m6 6 12 12"/>
        </svg>
      </button>
    </div>

    <!-- Mobile menu -->
    <div
      id="mobile-menu"
      class="hidden md:hidden pb-4 border-t border-border mt-1"
    >
      <ul class="pt-3 space-y-1">
        {navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class="block px-4 py-2.5 text-sm text-text-secondary hover:text-text-primary hover:bg-surface-3 rounded-lg transition-colors mobile-link"
              data-es={link.labelEs}
              data-en={link.labelEn}
            >
              {link.labelEs}
            </a>
          </li>
        ))}
      </ul>
      <!-- Mobile lang toggle -->
      <div class="px-4 pt-3 border-t border-border mt-2">
        <button
          id="lang-toggle-mobile"
          class="flex items-center gap-1.5 text-sm font-medium text-text-secondary hover:text-text-primary transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
          </svg>
          <span id="lang-label-mobile">English</span>
        </button>
      </div>
    </div>
  </nav>
</header>

<script>
  const nav = document.getElementById('nav');
  const menuBtn = document.getElementById('menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  // Scroll effect
  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) {
      nav?.classList.add('bg-surface/90', 'backdrop-blur-md', 'border-b', 'border-border');
    } else {
      nav?.classList.remove('bg-surface/90', 'backdrop-blur-md', 'border-b', 'border-border');
    }
  });

  // Mobile toggle
  menuBtn?.addEventListener('click', () => {
    const isOpen = !mobileMenu?.classList.contains('hidden');
    mobileMenu?.classList.toggle('hidden');
    iconOpen?.classList.toggle('hidden', !isOpen);
    iconClose?.classList.toggle('hidden', isOpen);
  });

  // Theme toggle
  const themeToggle = document.getElementById('theme-toggle');
  const iconMoon = document.getElementById('icon-moon');
  const iconSun = document.getElementById('icon-sun');
  const html = document.documentElement;

  // Apply saved theme on load
  if (localStorage.getItem('theme') === 'light') {
    html.classList.add('light');
    iconMoon?.classList.add('hidden');
    iconSun?.classList.remove('hidden');
  }

  themeToggle?.addEventListener('click', () => {
    const isLight = html.classList.toggle('light');
    localStorage.setItem('theme', isLight ? 'light' : 'dark');
    iconMoon?.classList.toggle('hidden', isLight);
    iconSun?.classList.toggle('hidden', !isLight);
  });

  // Close on link click
  document.querySelectorAll('.mobile-link').forEach((link) => {
    link.addEventListener('click', () => {
      mobileMenu?.classList.add('hidden');
      iconOpen?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
    });
  });

  // Sync mobile lang toggle with desktop
  const langToggleMobile = document.getElementById('lang-toggle-mobile');
  const langLabelMobile = document.getElementById('lang-label-mobile');
  if (langToggleMobile) {
    langToggleMobile.addEventListener('click', () => {
      const btn = document.getElementById('lang-toggle');
      btn?.click();
    });
  }
</script>
