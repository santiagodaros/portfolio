---
const navLinks = [
  { href: '#about', label: 'sobre mí' },
  { href: '#experience', label: 'experiencia' },
  { href: '#stack', label: 'stack' },
  { href: '#articles', label: 'artículos' },
  { href: '#contact', label: 'contacto' },
];
---

<header
  id="nav"
  class="sticky top-0 z-50 border-b border-border bg-surface/90 backdrop-blur-md"
>
  <nav class="max-w-[1200px] mx-auto px-5 sm:px-10">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2.5 font-mono font-semibold text-sm text-text-primary">
        <span class="pulse-square w-2 h-2 bg-accent"></span>~/santiago-daros
      </a>

      <!-- Desktop nav -->
      <div class="hidden md:flex items-center gap-1">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="font-mono text-xs text-text-secondary px-3.5 py-2 border border-transparent hover:border-border hover:bg-surface-3 hover:text-text-primary transition-colors"
          >
            ./{link.label}
          </a>
        ))}

        <!-- Theme toggle -->
        <button
          id="theme-toggle"
          class="ml-2.5 w-[30px] h-[30px] border border-border bg-surface-3 text-text-primary hover:border-accent transition-colors flex items-center justify-center"
          aria-label="Cambiar tema"
        >
          <svg id="icon-moon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/>
          </svg>
          <svg id="icon-sun" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden">
            <circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/>
          </svg>
        </button>
      </div>

      <!-- Mobile: theme + menu -->
      <div class="flex md:hidden items-center gap-2">
        <button
          id="theme-toggle-m"
          class="w-[30px] h-[30px] border border-border bg-surface-3 text-text-primary flex items-center justify-center"
          aria-label="Cambiar tema"
        >
          <svg id="icon-moon-m" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/>
          </svg>
          <svg id="icon-sun-m" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden">
            <circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/>
          </svg>
        </button>
        <button
          id="menu-btn"
          class="w-[30px] h-[30px] border border-border bg-surface-3 text-text-primary flex items-center justify-center"
          aria-label="Menu"
        >
          <svg id="icon-open" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/>
          </svg>
          <svg id="icon-close" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden">
            <path d="M18 6 6 18"/><path d="m6 6 12 12"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden md:hidden pb-4 border-t border-border">
      <ul class="pt-3 space-y-1">
        {navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class="mobile-link block font-mono text-xs text-text-secondary px-3 py-2.5 border border-transparent hover:border-border hover:bg-surface-3 hover:text-text-primary transition-colors"
            >
              ./{link.label}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </nav>
</header>

<script>
  const menuBtn = document.getElementById('menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  menuBtn?.addEventListener('click', () => {
    const isOpen = !mobileMenu?.classList.contains('hidden');
    mobileMenu?.classList.toggle('hidden');
    iconOpen?.classList.toggle('hidden', !isOpen);
    iconClose?.classList.toggle('hidden', isOpen);
  });

  document.querySelectorAll('.mobile-link').forEach((link) => {
    link.addEventListener('click', () => {
      mobileMenu?.classList.add('hidden');
      iconOpen?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
    });
  });

  // Theme toggle (desktop + mobile buttons)
  const html = document.documentElement;
  const moons = [document.getElementById('icon-moon'), document.getElementById('icon-moon-m')];
  const suns = [document.getElementById('icon-sun'), document.getElementById('icon-sun-m')];

  function applyIcons(isLight: boolean) {
    moons.forEach((m) => m?.classList.toggle('hidden', isLight));
    suns.forEach((s) => s?.classList.toggle('hidden', !isLight));
  }

  if (localStorage.getItem('theme') === 'light') {
    html.classList.add('light');
    applyIcons(true);
  }

  ['theme-toggle', 'theme-toggle-m'].forEach((id) => {
    document.getElementById(id)?.addEventListener('click', () => {
      const isLight = html.classList.toggle('light');
      localStorage.setItem('theme', isLight ? 'light' : 'dark');
      applyIcons(isLight);
    });
  });
</script>
