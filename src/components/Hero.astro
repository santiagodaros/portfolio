---
const stats = [
  { key: 'certificaciones =', value: '6' },
  { key: 'meses_en_cloud =', value: '12' },
  { key: 'formación =', value: 'UBA' },
];
---

<section id="hero" class="border-b border-border">
  <div class="max-w-[1200px] mx-auto px-5 sm:px-10 pt-14 sm:pt-16 pb-11 grid lg:grid-cols-[1fr_300px] gap-10">
    <!-- Text -->
    <div class="lg:pr-10 lg:border-r lg:border-border">
      <p class="font-mono text-xs text-accent mb-4 animate-on-scroll">$ whoami --role</p>

      <div class="inline-flex items-center gap-2 px-2.5 py-1.5 border border-border font-mono text-xs text-text-secondary mb-6 animate-on-scroll">
        <span class="pulse-square w-1.5 h-1.5"></span>
        Cloud Specialist @ readymind
      </div>

      <h1 class="font-mono font-bold text-4xl sm:text-5xl lg:text-[56px] leading-[1.02] tracking-tight animate-on-scroll">
        Santiago<br />
        <span class="accent-serif">Da Ros</span>
      </h1>

      <div class="typewriter mt-6 w-fit">
        <span class="font-mono text-sm text-text-secondary">Cloud Demand Hub · Lic. Cs. Computación (UBA)</span>
      </div>

      <p class="mt-6 max-w-[520px] font-mono text-[15px] leading-[1.7] text-text-secondary animate-on-scroll">
        Trabajo en entornos Nube (<strong class="text-text-primary font-semibold">Microsoft Azure</strong>),
        <strong class="text-text-primary font-semibold">Híbridos</strong> y
        <strong class="text-text-primary font-semibold">On-Prem</strong> gestionando incidentes,
        documentando procedimientos técnicos y trabajando directo con clientes.
      </p>

      <div class="flex flex-wrap gap-3 mt-8 animate-on-scroll">
        <a href="#experience" class="btn-solid">Ver_experiencia →</a>
        <a href="/cv.pdf" download class="btn-box">Descargar_CV ↓</a>
      </div>
    </div>

    <!-- Photo: bordered frame, terminal caption -->
    <div class="animate-on-scroll">
      <div class="border border-border p-3.5 bg-surface-3 max-w-[300px]">
        <img
          src="/foto.png"
          alt="Santiago Da Ros"
          class="w-full object-cover object-top"
          style="aspect-ratio: 1 / 1.15; filter: grayscale(0.3) contrast(1.05);"
        />
        <div class="mt-2.5 font-mono text-[11px] text-text-muted flex justify-between">
          <span>foto.png</span><span>1x1.15</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Stats strip -->
<div class="border-b border-border">
  <div class="max-w-[1200px] mx-auto grid grid-cols-1 sm:grid-cols-3">
    {stats.map((s, i) => (
      <div class={`px-5 sm:px-10 py-5 font-mono border-border ${i < 2 ? 'border-b sm:border-b-0 sm:border-r' : ''}`}>
        <div class="text-[11px] text-text-muted">{s.key}</div>
        <div class="text-[26px] font-bold mt-1 text-text-primary">{s.value}</div>
      </div>
    ))}
  </div>
</div>
