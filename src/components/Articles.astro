---
const publishedArticle = {
  tags: ['AzureBlobStorage', 'CostOptimization', 'DataTiering'],
  title: 'Almacenamiento inteligente: bajar costos archivando datos viejos',
  desc: 'Diseñar soluciones que equilibren escalabilidad, seguridad y costo-eficiencia es un desafío constante; hoy analizamos cómo aplicarlo en el almacenamiento de datos inactivos en Azure.',
  date: '20 Abr 2026',
  readTime: '5 min',
  link: 'https://www.linkedin.com/pulse/almacenamiento-inteligente-bajar-costos-archivando-datos-da-ros-xciuf',
};

const articleUpcoming = [
  { tags: ['AzureAD', 'EntraID'], title: 'Migración de identidades on-premise a Azure AD' },
  { tags: ['AzureArc', 'Hybrid'], title: 'Azure Arc: integrando infraestructura On-Prem con la nube' },
  { tags: ['FinOps', 'Azure'], title: 'FinOps en Azure: optimización de costos en suscripciones reales' },
];
---

<section id="articles" class="border-b border-border">
  <div class="max-w-[1200px] mx-auto px-5 sm:px-10 py-16">
    <div class="flex justify-between items-end flex-wrap gap-2.5 mb-8">
      <div>
        <p class="section-label animate-on-scroll">04 // articulos.sh</p>
        <h2 class="section-heading animate-on-scroll">
          Contenido técnico <span class="accent-serif">para la comunidad</span>
        </h2>
      </div>
      <a
        href="https://www.linkedin.com/in/santiagodaros/recent-activity/articles/"
        target="_blank"
        rel="noopener noreferrer"
        class="font-mono font-semibold text-xs text-text-secondary hover:text-accent transition-colors animate-on-scroll"
      >
        [ver_todos →]
      </a>
    </div>

    <!-- Published article -->
    <div class="box-alt p-6 animate-on-scroll">
      <div class="inline-flex items-center gap-[7px] font-mono font-bold text-[11px] text-tgreen border px-2 py-[3px] mb-3.5" style="border-color: var(--color-green)">
        <span class="pulse-square w-1.5 h-1.5"></span>publicado
      </div>
      <div class="font-mono font-bold text-lg sm:text-[19px] text-text-primary leading-snug">{publishedArticle.title}</div>
      <p class="mt-2.5 font-mono text-[13.5px] leading-relaxed text-text-secondary max-w-[760px]">{publishedArticle.desc}</p>
      <div class="mt-4 flex justify-between items-center flex-wrap gap-3">
        <div class="flex flex-wrap gap-2 font-mono text-[11.5px] text-text-muted">
          {publishedArticle.tags.map((tg) => (
            <span>#{tg}</span>
          ))}
          <span>· {publishedArticle.date} · {publishedArticle.readTime}</span>
        </div>
        <a
          href={publishedArticle.link}
          target="_blank"
          rel="noopener noreferrer"
          class="font-mono font-bold text-[12.5px] text-accent hover:opacity-80 transition-opacity"
        >
          [leer_en_linkedin ↗]
        </a>
      </div>
    </div>

    <!-- Upcoming -->
    <div class="mt-3 flex flex-col gap-2.5">
      {articleUpcoming.map((art, i) => (
        <div
          class="grid sm:grid-cols-[130px_1fr] gap-2 sm:gap-5 p-4 border border-dashed border-border animate-on-scroll"
          style={`transition-delay: ${i * 0.06}s`}
        >
          <div class="font-mono text-[11.5px] text-text-muted">próximamente</div>
          <div>
            <div class="font-mono text-sm text-text-secondary">{art.title}</div>
            <div class="mt-1.5 flex gap-2 font-mono text-[11px] text-text-muted">
              {art.tags.map((tg) => (
                <span>#{tg}</span>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
