---

<section id="articles" class="py-24 sm:py-32 bg-surface-1">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 relative overflow-hidden">
    <span class="section-deco-number">04</span>
    <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-4 mb-16">
      <div>
        <p class="section-title animate-from-left"
           data-es="Articulos"
           data-en="Articles">Articulos</p>
        <h2 class="section-heading animate-from-left" style="transition-delay:80ms">
          <span data-es="Contenido tecnico" data-en="Technical content">Contenido tecnico</span><br />
          <span class="text-accent"
                data-es="para la comunidad"
                data-en="for the community">para la comunidad</span>
        </h2>
      </div>
      <a
        href="https://www.linkedin.com/in/santiagodaros/recent-activity/articles/"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-outline text-sm shrink-0 animate-from-right self-start sm:self-auto"
      >
        <span data-es="Ver todos" data-en="View all">Ver todos</span>
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
        </svg>
      </a>
    </div>

    <div class="grid sm:grid-cols-2 gap-5">
      {articles.map((article, i) => (
        article.locked ? (
          <div
            class="card flex flex-col animate-on-scroll"
            style={`transition-delay: ${i * 80}ms`}
          >
            <!-- Blur overlay -->
            <div class="absolute inset-0 backdrop-blur-[3px] bg-surface-2/50 rounded-xl z-10 flex flex-col items-center justify-center gap-2 pointer-events-none">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-text-muted">
                <rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
              </svg>
              <span class="text-xs text-text-muted font-mono"
                    data-es="Próximamente" data-en="Coming soon">Próximamente</span>
            </div>
            <!-- Blurred content behind -->
            <div class="flex items-center justify-between mb-3">
              <div class="flex flex-wrap gap-1.5">
                {article.tags.slice(0, 2).map((tag) => (
                  <span class="tag text-xs">{tag}</span>
                ))}
              </div>
            </div>
            <h3 class="font-medium text-text-secondary text-sm leading-snug flex-1 mb-4">{article.titleEs}</h3>
            <p class="text-xs text-text-muted italic mb-4">{article.excerptEs}</p>
            <div class="flex items-center gap-2 mt-auto pt-3 border-t border-border">
              <img src="/foto.png" alt="Santiago Da Ros" class="w-8 h-8 rounded-full object-cover object-top" />
              <span class="text-xs text-text-muted">Santiago</span>
              <span class="text-xs text-text-muted ml-auto font-mono">{article.date}</span>
            </div>
          </div>
        ) : (
          <a
            href={article.link}
            target="_blank"
            rel="noopener noreferrer"
            class="card group cursor-pointer animate-on-scroll flex flex-col"
            style={`transition-delay: ${i * 80}ms`}
          >
            <div class="flex items-center justify-between mb-3">
              <div class="flex flex-wrap gap-1.5">
                {article.tags.slice(0, 2).map((tag) => (
                  <span class="tag text-xs">{tag}</span>
                ))}
              </div>
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-text-muted group-hover:text-accent group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-all duration-200 shrink-0">
                <path d="M7 7h10v10"/><path d="M7 17 17 7"/>
              </svg>
            </div>
            <h3 class="font-semibold text-text-primary text-base leading-snug group-hover:text-accent transition-colors flex-1 mb-3"
                data-es={article.titleEs}
                data-en={article.titleEn}>
              {article.titleEs}
            </h3>
            <p class="text-sm text-text-secondary leading-relaxed mb-4"
               data-es={article.excerptEs}
               data-en={article.excerptEn}>{article.excerptEs}</p>
            <div class="flex items-center gap-2 mt-auto pt-3 border-t border-border">
              <img src="/foto.png" alt="Santiago Da Ros" class="w-8 h-8 rounded-full object-cover object-top" />
              <span class="text-sm text-text-secondary font-medium">Santiago</span>
              <span class="text-xs text-text-muted ml-auto font-mono"
                    data-es={article.date}
                    data-en={article.dateEn}>{article.date}</span>
            </div>
          </a>
        )
      ))}
    </div>
  </div>
</section>
