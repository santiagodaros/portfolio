---
const articles = [
  {
    titleEs: 'Almacenamiento inteligente: Bajar costos archivando datos viejos',
    titleEn: 'Intelligent Storage: Reducing Costs by Archiving Old Data',
    excerptEs:
      'Diseñar soluciones que equilibren escalabilidad, seguridad y costo-eficiencia es un desafío constante; hoy analizamos cómo aplicarlo en el almacenamiento de datos inactivos en Azure.',
    excerptEn:
      'Designing solutions that balance scalability, security, and cost-efficiency is a constant challenge; today we analyze how to apply it to inactive data storage in Azure.',
    tags: ['Azure Blob Storage', 'Cost Optimization', 'Data Tiering'],
    date: '20 Abr 2026',
    dateEn: 'Apr 20, 2026',
    readTime: '5 min',
    locked: false,
    link: 'https://www.linkedin.com/pulse/almacenamiento-inteligente-bajar-costos-archivando-datos-da-ros-xciuf',
  },
  {
    titleEs: 'Migracion de identidades on-premise a Azure AD',
    titleEn: 'On-premise identity migration to Azure AD',
    excerptEs: 'Contenido disponible próximamente',
    excerptEn: 'Content coming soon',
    tags: ['Azure AD', 'Entra ID', 'Hybrid'],
    date: 'Próximamente',
    dateEn: 'Coming soon',
    readTime: '',
    locked: true,
    link: '#',
  },
  {
    titleEs: 'Azure Arc: integrando infraestructura On-Prem con la nube',
    titleEn: 'Azure Arc: integrating On-Prem infrastructure with the cloud',
    excerptEs: 'Contenido disponible próximamente',
    excerptEn: 'Content coming soon',
    tags: ['Azure Arc', 'Hybrid', 'Windows Server'],
    date: 'Próximamente',
    dateEn: 'Coming soon',
    readTime: '',
    locked: true,
    link: '#',
  },
  {
    titleEs: 'FinOps en Azure: optimización de costos en suscripciones reales',
    titleEn: 'FinOps in Azure: cost optimization in real subscriptions',
    excerptEs: 'Contenido disponible próximamente',
    excerptEn: 'Content coming soon',
    tags: ['FinOps', 'Azure', 'Cost'],
    date: 'Próximamente',
    dateEn: 'Coming soon',
    readTime: '',
    locked: true,
    link: '#',
  },
];
---

<section id="articles" class="py-24 sm:py-32 bg-surface-1">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 relative overflow-hidden">
    <span class="section-deco-number">04</span>
    <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-4 mb-16">
      <div>
        <p class="section-title animate-from-left"
           data-es="Articulos"
           data-en="Articles">Articulos</p>
        <h2 class="section-heading animate-from-left" style="transition-delay:80ms">
          <span data-es="Contenido tecnico" data-en="Technical content">Contenido tecnico</span><br />
          <span class="text-accent"
                data-es="para la comunidad"
                data-en="for the community">para la comunidad</span>
        </h2>
      </div>
      <a
        href="https://www.linkedin.com/in/santiagodaros/recent-activity/articles/"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-outline text-sm shrink-0 animate-from-right self-start sm:self-auto"
      >
        <span data-es="Ver todos" data-en="View all">Ver todos</span>
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
        </svg>
      </a>
    </div>

    <div class="space-y-4">

      {/* ── Featured article ── */}
      {articles.filter(a => !a.locked).map((article) => (
        <a
          href={article.link}
          target="_blank"
          rel="noopener noreferrer"
          class="group relative flex flex-col sm:flex-row gap-6 rounded-xl border border-border bg-surface-2 p-6 hover:border-accent/50 hover:bg-surface-3 transition-all duration-300 animate-on-scroll overflow-hidden"
        >
          <!-- Accent top bar -->
          <div class="absolute top-0 left-0 right-0 h-[2px] bg-gradient-to-r from-accent via-violet-400 to-transparent rounded-t-xl"></div>

          <!-- Left: content -->
          <div class="flex-1 flex flex-col">
            <!-- Top row: badges -->
            <div class="flex flex-wrap items-center gap-2 mb-4">
              <span class="inline-flex items-center gap-1 text-[10px] font-mono font-bold uppercase tracking-widest px-2 py-0.5 rounded bg-accent/15 text-accent border border-accent/25">
                <span class="w-1.5 h-1.5 rounded-full bg-accent inline-block"></span>
                <span data-es="Publicado" data-en="Published">Publicado</span>
              </span>
              {article.tags.map((tag) => (
                <span class="tag text-xs">{tag}</span>
              ))}
            </div>

            <!-- Title -->
            <h3 class="font-bold text-text-primary text-lg sm:text-xl leading-snug group-hover:text-accent transition-colors mb-3"
                data-es={article.titleEs}
                data-en={article.titleEn}>
              {article.titleEs}
            </h3>

            <!-- Excerpt -->
            <p class="text-sm text-text-secondary leading-relaxed flex-1 mb-5"
               data-es={article.excerptEs}
               data-en={article.excerptEn}>{article.excerptEs}</p>

            <!-- Footer -->
            <div class="flex items-center gap-3 pt-4 border-t border-border">
              <img src="/foto.png" alt="Santiago Da Ros" class="w-7 h-7 rounded-full object-cover object-top shrink-0" />
              <span class="text-xs text-text-secondary font-medium">Santiago Da Ros</span>
              <span class="text-text-muted text-xs">·</span>
              <span class="text-xs text-text-muted font-mono"
                    data-es={article.date}
                    data-en={article.dateEn}>{article.date}</span>
              {article.readTime && (
                <>
                  <span class="text-text-muted text-xs">·</span>
                  <span class="text-xs text-text-muted font-mono">{article.readTime} read</span>
                </>
              )}
              <span class="ml-auto inline-flex items-center gap-1 text-accent text-xs font-semibold group-hover:gap-2 transition-all duration-200">
                <span data-es="Leer artículo" data-en="Read article">Leer artículo</span>
                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M7 7h10v10"/><path d="M7 17 17 7"/>
                </svg>
              </span>
            </div>
          </div>
        </a>
      ))}

      {/* ── Locked articles grid ── */}
      <div class="grid sm:grid-cols-3 gap-4">
        {articles.filter(a => a.locked).map((article, i) => (
          <div
            class="card flex flex-col animate-on-scroll"
            style={`transition-delay: ${(i + 1) * 80}ms`}
          >
            <!-- Blur overlay -->
            <div class="absolute inset-0 backdrop-blur-[3px] bg-surface-2/60 rounded-xl z-10 flex flex-col items-center justify-center gap-2 pointer-events-none">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-text-muted">
                <rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
              </svg>
              <span class="text-[10px] text-text-muted font-mono uppercase tracking-widest"
                    data-es="Próximamente" data-en="Coming soon">Próximamente</span>
            </div>
            <!-- Blurred content -->
            <div class="flex flex-wrap gap-1.5 mb-3">
              {article.tags.slice(0, 2).map((tag) => (
                <span class="tag text-[10px]">{tag}</span>
              ))}
            </div>
            <h3 class="font-medium text-text-muted text-xs leading-snug flex-1 mb-3">{article.titleEs}</h3>
            <div class="flex items-center gap-2 mt-auto pt-3 border-t border-border/60">
              <img src="/foto.png" alt="Santiago Da Ros" class="w-6 h-6 rounded-full object-cover object-top opacity-50" />
              <span class="text-[10px] text-text-muted">Santiago Da Ros</span>
            </div>
          </div>
        ))}
      </div>

    </div>
  </div>
</section>
