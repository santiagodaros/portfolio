---
const contactLinks = [
  {
    label: 'LinkedIn',
    value: 'linkedin.com/in/santiagodaros',
    href: 'https://www.linkedin.com/in/santiagodaros',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>`,
  },
  {
    label: 'Email',
    value: 'santiagolucasdaros@gmail.com',
    href: 'mailto:santiagolucasdaros@gmail.com',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>`,
  },
];
---

<section id="contact" class="py-24 sm:py-32">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="max-w-2xl mx-auto text-center">
      <p class="section-title animate-on-scroll">Contacto</p>
      <h2 class="section-heading mb-4 animate-on-scroll">
        Hablemos de tu<br />
        <span class="text-accent">infraestructura</span>
      </h2>
      <p class="text-text-secondary leading-relaxed mb-10 animate-on-scroll">
        Ya sea que necesites optimizar tu infraestructura Cloud, automatizar procesos 
        operacionales o simplemente quieras conectar, estoy disponible para conversar.
      </p>

      <!-- Contact cards -->
      <div class="grid sm:grid-cols-2 gap-3 mb-10 max-w-xs mx-auto">
        {contactLinks.map((link, i) => (
          <a
            href={link.href}
            target={link.href.startsWith('mailto') ? '_self' : '_blank'}
            rel="noopener noreferrer"
            class="card group text-left animate-on-scroll"
            style={`animation-delay: ${i * 0.1}s`}
          >
            <div class="text-text-secondary group-hover:text-accent transition-colors mb-3" set:html={link.icon} />
            <p class="text-sm font-medium text-text-primary group-hover:text-accent transition-colors">{link.label}</p>
          </a>
        ))}
      </div>

      <!-- CTA -->
      <div class="animate-on-scroll">
        <a
          href="mailto:santiagolucasdaros@gmail.com"
          class="btn-primary text-base px-8 py-3.5"
        >
          Enviar mensaje
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>

<!-- Footer -->
<footer class="border-t border-border py-8">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="font-mono text-xs text-text-muted">
        <span class="text-accent">~/</span>santiago-daros &copy; {new Date().getFullYear()}
      </p>
      <div class="flex items-center gap-4">
        <a href="https://www.linkedin.com/in/santiagodaros" target="_blank" rel="noopener noreferrer" class="text-text-muted hover:text-accent transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
        </a>
        <p class="text-xs text-text-muted">
          Construido con <span class="text-text-secondary">Astro</span> + <span class="text-text-secondary">Tailwind CSS</span>
        </p>
      </div>
    </div>
  </div>
</footer>
