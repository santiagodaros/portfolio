---
// Email intentionally absent from the static HTML: it gets decoded and
// injected client-side (see script below) so scraper bots can't harvest it.
const links = [
  { label: 'linkedin/santiagodaros', href: 'https://www.linkedin.com/in/santiagodaros', external: true },
  { label: 'github/santiagodaros', href: 'https://github.com/santiagodaros', external: true },
];
---

<section id="contact">
  <div class="max-w-[1200px] mx-auto px-5 sm:px-10 py-[70px] text-center">
    <p class="font-mono text-xs text-accent animate-on-scroll" data-es="05 // contacto.sh" data-en="05 // contact.sh">05 // contacto.sh</p>
    <h2 class="section-heading mt-4 animate-on-scroll">
      <span data-es="Hablemos de tu " data-en="Let's talk about your ">Hablemos de tu </span><span class="accent-serif" data-es="infraestructura" data-en="infrastructure">infraestructura</span>
    </h2>
    <p
      class="max-w-[520px] mx-auto mt-4 font-mono text-sm leading-relaxed text-text-secondary animate-on-scroll"
      data-es="Ya sea que necesites optimizar tu infraestructura Cloud, automatizar procesos operacionales o simplemente quieras conectar, estoy disponible para conversar."
      data-en="Whether you need to optimize your Cloud infrastructure, automate operational processes, or simply want to connect, I'm available to chat."
    >
      Ya sea que necesites optimizar tu infraestructura Cloud, automatizar procesos
      operacionales o simplemente quieras conectar, estoy disponible para conversar.
    </p>

    <div class="mt-6 flex justify-center items-center gap-3 sm:gap-4 font-mono text-[12.5px] flex-wrap animate-on-scroll">
      <a
        href={links[0].href}
        target="_blank"
        rel="noopener noreferrer"
        class="text-text-secondary underline underline-offset-4 hover:text-accent transition-colors"
      >
        {links[0].label}
      </a>
      <span class="text-text-muted hidden sm:inline">·</span>
      <a
        id="email-link"
        href="#contact"
        class="text-text-secondary underline underline-offset-4 hover:text-accent transition-colors"
      >
        email
      </a>
      <span class="text-text-muted hidden sm:inline">·</span>
      <a
        href={links[1].href}
        target="_blank"
        rel="noopener noreferrer"
        class="text-text-secondary underline underline-offset-4 hover:text-accent transition-colors"
      >
        {links[1].label}
      </a>
    </div>

    <a id="email-cta" href="#contact" class="btn-solid mt-7 font-bold" data-es="Enviar_mensaje →" data-en="Send_message →">
      Enviar_mensaje →
    </a>
  </div>
</section>

<script>
  // Assemble the email client-side so it never appears in the static HTML
  const email = atob('c2FudGlhZ29sdWNhc2Rhcm9zQGdtYWlsLmNvbQ==');
  const emailLink = document.getElementById('email-link');
  if (emailLink instanceof HTMLAnchorElement) {
    emailLink.href = `mailto:${email}`;
    emailLink.textContent = email;
  }
  const emailCta = document.getElementById('email-cta');
  if (emailCta instanceof HTMLAnchorElement) emailCta.href = `mailto:${email}`;
</script>

<!-- Footer -->
<footer class="border-t border-border">
  <div class="max-w-[1200px] mx-auto px-5 sm:px-10 py-5 flex flex-col sm:flex-row items-center justify-between gap-2 font-mono text-[11.5px] text-text-muted">
    <span>~/santiago-daros © {new Date().getFullYear()}</span>
    <span>Astro + Tailwind</span>
  </div>
</footer>
