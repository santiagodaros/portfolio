---
const links = [
  { label: 'linkedin/santiagodaros', href: 'https://www.linkedin.com/in/santiagodaros', external: true },
  { label: 'santiagolucasdaros@gmail.com', href: 'mailto:santiagolucasdaros@gmail.com', external: false },
  { label: 'github/santiagodaros', href: 'https://github.com/santiagodaros', external: true },
];
---

<section id="contact">
  <div class="max-w-[1200px] mx-auto px-5 sm:px-10 py-[70px] text-center">
    <p class="font-mono text-xs text-accent animate-on-scroll">05 // contacto.sh</p>
    <h2 class="section-heading mt-4 animate-on-scroll">
      Hablemos de tu <span class="accent-serif">infraestructura</span>
    </h2>
    <p class="max-w-[520px] mx-auto mt-4 font-mono text-sm leading-relaxed text-text-secondary animate-on-scroll">
      Ya sea que necesites optimizar tu infraestructura Cloud, automatizar procesos
      operacionales o simplemente quieras conectar, estoy disponible para conversar.
    </p>

    <div class="mt-6 flex justify-center items-center gap-3 sm:gap-4 font-mono text-[12.5px] flex-wrap animate-on-scroll">
      {links.map((link, i) => (
        <>
          {i > 0 && <span class="text-text-muted hidden sm:inline">·</span>}
          <a
            href={link.href}
            target={link.external ? '_blank' : '_self'}
            rel={link.external ? 'noopener noreferrer' : undefined}
            class="text-text-secondary underline underline-offset-4 hover:text-accent transition-colors"
          >
            {link.label}
          </a>
        </>
      ))}
    </div>

    <a href="mailto:santiagolucasdaros@gmail.com" class="btn-solid mt-7 font-bold">
      Enviar_mensaje →
    </a>
  </div>
</section>

<!-- Footer -->
<footer class="border-t border-border">
  <div class="max-w-[1200px] mx-auto px-5 sm:px-10 py-5 flex flex-col sm:flex-row items-center justify-between gap-2 font-mono text-[11.5px] text-text-muted">
    <span>~/santiago-daros © {new Date().getFullYear()}</span>
    <span>Astro + Tailwind</span>
  </div>
</footer>
